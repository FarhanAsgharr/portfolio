# Copy this file to .env.local and fill in your own values.
#
# 1. DATABASE_URL — where your content is stored.
#    Get a free one from https://neon.tech or https://supabase.com
#    It looks like: postgres://user:password@host/dbname?sslmode=require
DATABASE_URL=

# 2. ADMIN_PASSWORD — what you type to sign in at /admin.
#    Use something long. Anyone with this can edit your site.
ADMIN_PASSWORD=

# 3. ADMIN_SECRET — optional. Signs your login session.
#    Changing it signs you out everywhere. Any long random string works.
ADMIN_SECRET=

# 4. Contact form email (optional). Without these the form still works,
#    validates and rate-limits — it just doesn't send mail.
RESEND_API_KEY=
CONTACT_TO_EMAIL=
