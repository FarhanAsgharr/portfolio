# Copy this file to .env.local and fill in your own values.
#
# 1. DATABASE_URL — where your content is stored.
#    Get a free one from https://supabase.com (or https://neon.tech)
#    Supabase (transaction pooler): postgresql://postgres.xxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres
DATABASE_URL=

# 2. ADMIN_PASSWORD — what you type to sign in at /admin.
#    Use something long. Anyone with this can edit your site.
ADMIN_PASSWORD=

# 3. ADMIN_SECRET — optional. Signs your login session.
#    Changing it signs you out everywhere. Any long random string works.
ADMIN_SECRET=

# 4. Contact form email (optional). Without these the form still works,
#    validates and rate-limits — it just doesn't send mail.
RESEND_API_KEY=
CONTACT_TO_EMAIL=

# 5. Forgot-password over SMS (optional).
#
#    ADMIN_PHONE is the ONLY number a reset code is ever sent to. Set it to
#    your own mobile, with country code. If left blank, the phone number in
#    your site content (the Contact tab) is used instead.
ADMIN_PHONE=

#    Twilio actually delivers the SMS. Without these three, the reset flow
#    still works end to end, but instead of texting the code it shows it on
#    screen (dev mode) / logs it (production) — useful for testing, not for
#    real use. Get them free at https://twilio.com/try-twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
